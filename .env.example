# Porous Being Environment Configuration
# Copy this to .env file and adjust values as needed

# Build Environment
VITE_APP_NAME=Porous Being
VITE_APP_DESCRIPTION=Architecture & Design Portfolio
VITE_APP_URL=https://porous-being.com

# API Configuration (if needed in future)
VITE_API_URL=https://api.porous-being.com
VITE_API_TIMEOUT=30000

# Analytics (optional)
VITE_GA_ID=G-XXXXXXXXXX
VITE_ENABLE_ANALYTICS=false

# Feature Flags
VITE_ENABLE_LAP_LOADING=true
VITE_ENABLE_SMOOTH_SCROLL=true
VITE_ENABLE_SEO_META=true

# Performance
VITE_IMAGE_LAZY_LOAD_MARGIN=50px
VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_MINIFICATION=true

# Development
VITE_DEBUG_MODE=false
VITE_VERBOSE_LOGGING=false

# Production
VITE_ENV=production
